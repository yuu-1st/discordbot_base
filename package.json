{
  "name": "discordbot_base",
  "version": "1.0.0",
  "description": "discord.jsを使ったbotを作成する基盤となるリポジトリです",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "about:compile:": "echo 'src/をコンパイルします。'",
    "compile": "tsc",
    "about:start": "echo 'dist/index.jsをコンパイルし、実行します。'",
    "start": "tsc && node --enable-source-maps dist/index.js",
    "about:ts-start": "echo 'src/index.tsを実行します。'",
    "ts-start": "ts-node src/index.ts",
    "about:run": "echo 'dist/index.jsを実行します。'",
    "run": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuu-1st/discordbot_base.git"
  },
  "keywords": [],
  "author": "yuu-1st",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yuu-1st/discordbot_base/issues"
  },
  "homepage": "https://github.com/yuu-1st/discordbot_base#readme",
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@typescript-eslint/eslint-plugin": "^5.48.1",
    "@typescript-eslint/parser": "^5.48.1",
    "eslint": "^8.31.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "discord.js": "^14.7.1",
    "log4js": "^6.7.1"
  }
}
